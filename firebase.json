{
  "hosting": {
    "site": "sayyes-485207",
    "public": "staticfiles",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/admin",
        "destination": "https://solohub-tgb6xr7dcq-ew.a.run.app/admin/",
        "type": 301
      },
      {
        "source": "/admin/**",
        "destination": "https://solohub-tgb6xr7dcq-ew.a.run.app/admin/:splat",
        "type": 301
      },
      {
        "source": "/api",
        "destination": "https://solohub-tgb6xr7dcq-ew.a.run.app/api/",
        "type": 301
      },
      {
        "source": "/api/**",
        "destination": "https://solohub-tgb6xr7dcq-ew.a.run.app/api/:splat",
        "type": 301
      },
      {
        "source": "/",
        "destination": "https://solohub-tgb6xr7dcq-ew.a.run.app/",
        "type": 301
      }
    ],
    "headers": [
      {
        "source": "/static/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          }
        ]
      }
    ]
  }
}

